{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "outDir": "out-test",
    "rootDir": "src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "mocha", "vscode"]
  },
  "include": ["src/test/**/*.ts", "src/shared/**/*.ts"]
}
